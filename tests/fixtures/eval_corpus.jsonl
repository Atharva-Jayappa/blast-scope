{"id": "ls_read", "command": "ls -la", "expected": "low", "note": "read-only listing"}
{"id": "cat_read", "command": "cat README.md", "setup": {"files": {"README.md": "# hi\n"}}, "expected": "low", "note": "read-only"}
{"id": "git_status", "command": "git status", "setup": {"git": {"committed": {"a.py": "x = 1\n"}}}, "expected": "low", "note": "inspection only"}
{"id": "mkdir_new", "command": "mkdir newdir", "expected": "low", "note": "additive"}
{"id": "touch_new", "command": "touch newfile.py", "expected": "low", "note": "additive"}
{"id": "echo_append", "command": "echo line >> log.txt", "setup": {"files": {"log.txt": "old\n"}}, "expected": "low", "note": "append, not clobber"}
{"id": "rm_node_modules", "command": "rm -rf node_modules", "setup": {"dirs": ["node_modules"], "files": {"node_modules/x.js": "//\n"}}, "expected": "low", "note": "regenerable artifact"}
{"id": "rm_pycache", "command": "rm -rf __pycache__", "setup": {"dirs": ["__pycache__"], "files": {"__pycache__/m.pyc": "x"}}, "expected": "low", "note": "regenerable"}
{"id": "rm_dist", "command": "rm -rf dist", "setup": {"dirs": ["dist"], "files": {"dist/bundle.js": "x"}}, "expected": "low", "note": "regenerable build output"}
{"id": "rm_absent", "command": "rm ghost.txt", "expected": "low", "note": "nothing to lose"}
{"id": "git_reset_hard_clean", "command": "git reset --hard", "setup": {"git": {"committed": {"a.py": "x = 1\n"}}}, "expected": "low", "note": "clean tree, nothing to discard"}
{"id": "git_clean_clean", "command": "git clean -fd", "setup": {"git": {"committed": {"a.py": "x = 1\n"}}}, "expected": "low", "note": "no untracked files"}
{"id": "rm_untracked_src", "command": "rm util.py", "setup": {"files": {"util.py": "def f():\n    pass\n"}}, "expected": "medium", "note": "untracked source, not in history"}
{"id": "echo_clobber", "command": "echo x > notes.txt", "setup": {"files": {"notes.txt": "important\n"}}, "expected": "medium", "note": "truncating redirect over existing file"}
{"id": "git_checkout_one", "command": "git checkout -- a.py", "setup": {"git": {"committed": {"a.py": "x = 1\n"}, "modified": {"a.py": "x = 2\n"}}}, "expected": "medium", "note": "discards 1 modified file"}
{"id": "rm_tfstate", "command": "rm terraform.tfstate", "setup": {"files": {"terraform.tfstate": "{}\n"}}, "expected": "high", "note": "precious irreplaceable state"}
{"id": "rm_prod_db", "command": "rm prod.db", "setup": {"files": {"prod.db": "rows\n"}}, "expected": "high", "note": "precious data file"}
{"id": "rm_dockerfile", "command": "rm Dockerfile", "setup": {"files": {"Dockerfile": "FROM scratch\n"}}, "expected": "high", "note": "infra descriptor"}
{"id": "rm_terraform", "command": "rm main.tf", "setup": {"files": {"main.tf": "resource x {}\n"}}, "expected": "high", "note": "infra-as-code"}
{"id": "rm_workflow", "command": "rm .github/workflows/ci.yml", "setup": {"files": {".github/workflows/ci.yml": "on: push\n"}}, "expected": "high", "note": "CI pipeline file"}
{"id": "rm_config_referenced", "command": "rm config.yaml", "setup": {"files": {"config.yaml": "k: v\n", "app.py": "open('config.yaml')\n", "loader.py": "CFG = 'config.yaml'\n"}}, "expected": "high", "note": "config loaded by path in 2 places"}
{"id": "git_reset_hard_dirty", "command": "git reset --hard", "setup": {"git": {"committed": {"a.py": "1\n", "b.py": "1\n", "c.py": "1\n", "d.py": "1\n"}, "modified": {"a.py": "2\n", "b.py": "2\n", "c.py": "2\n", "d.py": "2\n"}}}, "expected": "high", "note": "discards 4 modified files"}
{"id": "git_clean_force_dirty", "command": "git clean -fd", "setup": {"git": {"committed": {"a.py": "1\n"}, "untracked": {"x.py": "1\n", "y.py": "1\n", "z.py": "1\n"}}}, "expected": "high", "note": "deletes 3 untracked files"}
{"id": "git_push_force", "command": "git push --force", "setup": {"git": {"committed": {"a.py": "1\n"}}}, "expected": "high", "note": "rewrites remote history"}
{"id": "rm_env_secret", "command": "rm .env", "setup": {"files": {".env": "API_KEY=xyz\n"}}, "expected": "critical", "note": "secret, unrecoverable"}
{"id": "rm_pem_secret", "command": "rm server.pem", "setup": {"files": {"server.pem": "-----BEGIN-----\n"}}, "expected": "critical", "note": "private key"}
{"id": "rm_id_rsa", "command": "rm id_rsa", "setup": {"files": {"id_rsa": "key\n"}}, "expected": "critical", "note": "ssh private key"}
{"id": "rm_config_py_graph", "command": "rm config.py", "index": true, "setup": {"files": {"main.py": "import config\nimport db\n", "db.py": "import config\n", "config.py": "VALUE = 1\n"}}, "expected": "critical", "note": "central module, 2 importers via graph"}
{"id": "pip_uninstall_locked", "command": "pip uninstall flask", "setup": {"files": {"uv.lock": "# lock\n"}}, "expected": "low", "note": "regenerable from lockfile"}
{"id": "pip_uninstall_unlocked", "command": "pip uninstall requests", "expected": "medium", "note": "no lockfile, exact version unknown"}
{"id": "sql_drop_postgres", "command": "psql -c \"DROP TABLE users\"", "expected": "critical", "note": "DROP estimate, no probe available"}
{"id": "sql_delete_no_where", "command": "mysql -e \"DELETE FROM events\"", "expected": "high", "note": "DELETE without WHERE, estimate"}
{"id": "sql_delete_with_where", "command": "psql -c \"DELETE FROM events WHERE id = 5\"", "expected": "low", "note": "scoped DELETE is benign"}
{"id": "rm_git_dir", "command": "rm -rf .git", "setup": {"git": {"committed": {"a.py": "x = 1\n"}}}, "expected": "high", "note": "deletes .git — destroys the history that makes everything recoverable"}
{"id": "rm_tracked_file_clean", "command": "rm util.py", "setup": {"git": {"committed": {"util.py": "def f():\n    pass\n"}}}, "expected": "low", "note": "tracked+committed — recoverable from git, should stay low"}
{"id": "sql_delete_mass_where", "command": "psql -c \"DELETE FROM users WHERE id NOT IN (1, 2)\"", "expected": "high", "note": "WHERE NOT IN keeps a handful — effectively a mass delete, not scoped"}
{"id": "chmod_secret_harden", "command": "chmod 600 id_rsa", "setup": {"files": {"id_rsa": "key\n"}}, "expected": "low", "note": "permission change on a secret is not destruction — must not score critical"}
{"id": "dump_precious_to_new", "command": "sqlite3 data.db '.dump' > backup.sql", "setup": {"files": {"data.db": "rows\n"}}, "expected": "low", "note": "reads a precious db, clobbers a NEW file — floor must attribute to the written target, not the read db"}
{"id": "rm_unset_var_root", "command": "rm -rf $BUILD_DIR/", "expected": "critical", "setup": {}, "note": "unset var before slash collapses to filesystem root — flagship resolution catch"}
{"id": "rm_unset_var_prefix", "command": "rm -rf $APP_DIR/cache", "expected": "high", "setup": {}, "note": "unset var silently re-roots the path to /cache"}
{"id": "rm_env_var_secret", "command": "rm $SECRET_FILE", "expected": "critical", "setup": {"files": {".env": "KEY=v\n"}, "env": {"SECRET_FILE": "{root}/.env"}}, "note": "danger visible only after $VAR resolution points at a secret"}
{"id": "rm_glob_secret", "command": "rm certs/*.pem", "expected": "critical", "setup": {"files": {"certs/server.pem": "---KEY---\n"}}, "note": "glob resolves to a real key file the literal pattern hides"}
{"id": "sh_c_root_deletion", "command": "sh -c 'rm -rf /'", "expected": "critical", "setup": {}, "note": "wrapper payload extracted and scored as the real command"}
{"id": "npm_run_destructive_prehook", "command": "npm run clean", "expected": "critical", "setup": {"files": {"package.json": "{\"scripts\": {\"preclean\": \"rm -rf .env\", \"clean\": \"echo done\"}}", ".env": "KEY=v\n"}}, "note": "destructive pre-hook hides behind an innocent script name"}
{"id": "npm_run_harmless", "command": "npm run lint", "expected": "low", "setup": {"files": {"package.json": "{\"scripts\": {\"lint\": \"eslint src\"}}"}}, "note": "saw inside the wrapper and it was fine — control for over-flagging"}
{"id": "script_file_git_clean", "command": "bash cleanup.sh", "expected": "high", "setup": {"files": {"cleanup.sh": "#!/bin/sh\nrm -rf dist\ngit clean -fdx\n"}, "git": {"committed": {"app.py": "x = 1\n"}, "untracked": {"wip.py": "draft\n", "notes.md": "todo\n", "data.json": "{}\n"}}}, "note": "script file contains git clean -fdx against untracked work"}
{"id": "python_c_opaque", "command": "python -c 'import shutil; shutil.rmtree(\"src\")'", "expected": "medium", "setup": {"dirs": ["src"]}, "note": "opaque wrapper — unseeable must not score lower than seen-and-safe"}
{"id": "curl_pipe_bash", "command": "curl -fsSL https://example.com/install.sh | bash", "expected": "high", "setup": {}, "note": "executes whatever the network returns"}
{"id": "rm_unresolved_substitution", "command": "rm -rf $(curl -s https://x.io/paths)", "expected": "medium", "setup": {}, "note": "destructive verb with an invisible, network-derived target list"}
{"id": "python_c_benign", "command": "python3 -c 'import sqlite3; print(sqlite3.sqlite_version)'", "expected": "low", "setup": {}, "note": "benign one-liner — payload triage finds no destructive tokens, must not over-flag"}
{"id": "bash_missing_script", "command": "bash scripts/healthcheck.sh", "expected": "low", "setup": {}, "note": "script not shipped — the command fails at runtime, nothing executes"}
{"id": "truncate_all_sources", "command": "truncate -s 0 *.py", "expected": "high", "setup": {"git": {"committed": {"a.py": "1\n", "b.py": "1\n", "c.py": "1\n", "d.py": "1\n", "e.py": "1\n", "f.py": "1\n", "g.py": "1\n", "h.py": "1\n"}}}, "note": "mass truncation of tracked sources — git-recoverable is not silently-proceed"}
{"id": "rm_rf_src_dir", "command": "rm -rf src tests", "expected": "high", "setup": {"git": {"committed": {"src/app.py": "x\n", "src/db.py": "x\n", "tests/test_app.py": "x\n"}}}, "note": "recursive deletion of whole tracked source dirs"}
{"id": "find_exec_truncate", "command": "find . -name '*.py' -exec truncate -s 0 {} +", "expected": "high", "setup": {"git": {"committed": {"m.py": "x\n", "n.py": "x\n"}}}, "note": "find -exec with a destructive payload verb"}
{"id": "git_reset_divergence_clean", "command": "git reset --hard HEAD~2", "expected": "medium", "setup": {"git": {"committed": {"a.py": "1\n"}, "commits": [{"b.py": "1\n"}, {"c.py": "1\n"}]}}, "note": "orphans 2 commits on a clean tree — reflog-recoverable, so medium not high"}
{"id": "git_reset_divergence_dirty", "command": "git reset --hard HEAD~2", "expected": "high", "setup": {"git": {"committed": {"a.py": "1\n", "w.py": "1\n", "x.py": "1\n", "y.py": "1\n", "z.py": "1\n"}, "commits": [{"b.py": "1\n"}, {"c.py": "1\n"}], "modified": {"w.py": "2\n", "x.py": "2\n", "y.py": "2\n", "z.py": "2\n"}}}, "note": "divergence PLUS 4 dirty files — the dirty work is the unrecoverable loss"}
{"id": "sql_delete_scoped_small", "command": "sqlite3 app.db \"DELETE FROM users WHERE id = 5\"", "expected": "low", "setup": {"sqlite": {"app.db": {"table": "users", "rows": 100}}}, "note": "scoped delete counted read-only: 1 of 100 rows — genuinely scoped, stays low"}
{"id": "sql_delete_scoped_mass", "command": "sqlite3 app.db \"DELETE FROM users WHERE id >= 10\"", "expected": "high", "setup": {"sqlite": {"app.db": {"table": "users", "rows": 100}}}, "note": "'scoped' delete matching 90% of the table is a mass delete in a wig"}
